# Copy to .env.local and fill in.

# Shared team password gating the whole app (see src/middleware.ts).
# Leave unset in local dev to skip the login gate entirely.
SITE_PASSWORD=

# From your Supabase project settings (API section). Leave unset to fall
# back to this browser's localStorage for Save/Open/Delete.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
